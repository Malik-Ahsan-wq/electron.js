```gitignore
# Dependencies
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime files
pids/
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build output
dist/
build/
out/
release/

# Electron Builder
*.exe
*.msi
*.dmg
*.AppImage
*.deb
*.rpm
*.snap

# Cache
.cache/
.parcel-cache/
.eslintcache

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS files
.DS_Store
Thumbs.db

# Coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
```
