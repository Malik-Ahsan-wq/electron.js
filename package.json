{
  "name": "electron-todo-app",
  "version": "1.0.0",
  "description": "Production-ready Desktop Todo App",
 "main": "dist/main.js",
  "author": "Your Name",
  "license": "ISC",
"scripts": {
  "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
  "dev:next": "cd renderer && npm run dev",
  "dev:electron": "wait-on http://localhost:3000 && tsc -p tsconfig.electron.json && electron .",
  "build": "npm run build:renderer && npm run build:electron",
  "build:renderer": "cd renderer && npm run build",
  "build:electron": "tsc -p tsconfig.electron.json",
  "dist": "npm run build && electron-builder",
  "dist:win": "npm run build && electron-builder --win",
  "start": "electron .",
  "lint": "cd renderer && npm run lint"
},
  "build": {
    "appId": "com.yourname.todoapp",
    "productName": "TodoApp",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TodoApp"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Office"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron-window-state": "^5.0.3",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.5",
    "@types/sql.js": "^1.4.11",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  }
}
